{
  "name": "venturi",
  "version": "1.0.0",
  "private": true,
  "description": "Venturi — Plataforma Multiplataforma para Empreendedores Solo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build:tokens": "npm run build --workspace=packages/design-tokens"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}